Content-Type: application/json

{
  "client": {
    "name": "João Silva",
    "email": "joao@email.com"
  },
  "products": [
    {
      "product_id": 1,
      "quantity": 2
    }
  ],
  "card": {
    "number": "5569000000006063",
    "cvv": "010"
  }
}

###

# CVV "100" força erro no Gateway 1 para validar o fallback automático
POST {{baseUrl}}/purchase
Content-Type: application/json

{
  "client": {
    "name": "Maria Lima",
    "email": "maria@email.com"
  },
  "products": [
    {
      "product_id": 1,
      "quantity": 1
    }
  ],
  "card": {
    "number": "5569000000006063",
    "cvv": "100"
  }
}

